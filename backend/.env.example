# LeafScan v2 Environment Configuration
# Copy this file to .env and fill in the actual values

# ── Application ──────────────────────────────────────────────────────────────
APP_NAME=Crop Disease Detection API
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=production
HOST=0.0.0.0
PORT=8000

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string
# Format: postgresql://username:password@localhost:5432/dbname
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/crop_disease_db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=30

# ── JWT Authentication ────────────────────────────────────────────────────────
# Generate a secure 32+ character string
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── File Upload ───────────────────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/jpg

# ── ML Models ─────────────────────────────────────────────────────────────────
PLANT_VALIDATOR_MODEL_PATH=models/plant_validator.h5
DISEASE_MODEL_PATH=models/disease_model.keras
DISEASE_LABEL_MAP_PATH=models/label_map.json
CONFIDENCE_THRESHOLD=0.75
PREDICTION_MODE=hybrid

# ── Gemini API (For Disease Detection Fallback) ───────────────────────────────
# Get your API key from: https://aistudio.google.com/app/apikeys
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash
GEMINI_IMAGE_MODEL=
GEMINI_TEXT_MODEL=
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta/models

# ── Multi-Language Support ────────────────────────────────────────────────────
SUPPORTED_LANGUAGES=en,hi,ta,te,mr,bn,gu,kn,ml,pa,fr,es,de,zh,ar,pt,it,ja,ko
DEFAULT_LANGUAGE=en

# ── CORS Configuration ────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,https://yourdomain.com

# ── Text-to-Speech (TTS) ──────────────────────────────────────────────────────
TTS_ENABLED=true
TTS_PROVIDER=google

# Google Cloud TTS
GOOGLE_TTS_API_KEY=your-google-tts-api-key-here
GOOGLE_TTS_LANGUAGE_CODE=en-US

# Servaai TTS (Alternative)
SERVAAI_API_KEY=your-servaai-api-key-here
SERVAAI_VOICE_ID=en-US-Neural2-A

TTS_STORAGE_DIR=uploads/tts

# ── RAG (Retrieval-Augmented Generation) ──────────────────────────────────────
RAG_ENABLED=true
RAG_UPLOAD_DIR=uploads/rag/documents
RAG_VECTOR_DB_DIR=uploads/rag/vectordb

# RAG Configuration
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=150
RAG_TOP_K_DOCS=6
RAG_FETCH_K=12

# Embeddings Model
EMBEDDING_MODEL=paraphrase-multilingual-mpnet-base-v2
EMBEDDING_DIMENSION=768

# ── LLM for Disease Precautions (Primary: Groq, Fallback: Gemini) ───────────────────
# This generates disease management advice in multilingual format
# Get keys from:
#   Groq: https://console.groq.com/keys
#   Gemini: https://makersuite.google.com/app/apikey

# GROQ (Primary LLM — Better Quality)
# Model: llama3-70b-8192 (high quality, fast reasoning)
# ⚠️  Change GROQ_MODEL here to switch models — no code changes needed!
# Available models: llama3-70b-8192, mixtral-8x7b-32768, gemma-7b-it
# Get API key from: https://console.groq.com/keys
# Free tier: 30 requests/min
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama3-70b-8192
GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions

# GEMINI (Fallback LLM — Used if Groq fails)
# Model: gemini-2.0-flash (lightweight and fast)
# Free tier: 15 requests/min (limited)
# Note: Already defined above but included here for clarity
# GEMINI_API_KEY=    (see above)
# GEMINI_MODEL=      (see above)
# GEMINI_API_URL=    (see above)

# GROQ (RAG LLM — Different from disease precautions)
# Model: llama-3.1-8b-versatile (for RAG/Q&A)
GROQ_RAG_API_KEY=your-groq-rag-api-key-here
GROQ_RAG_MODEL=llama-3.1-8b-versatile

# ── CORS (Frontend Origins) ──────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Text-to-Speech (TTS) ─────────────────────────────────────────────────────────────
TTS_ENABLED=false
TTS_PROVIDER=google
GOOGLE_TTS_API_KEY=your-google-tts-api-key-here
GOOGLE_TTS_LANGUAGE_CODE=en-US
SERVAAI_API_KEY=your-servaai-api-key-here
SERVAAI_VOICE_ID=en-US-Neural2-A
TTS_STORAGE_DIR=uploads/tts
